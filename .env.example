# =============================================================================
# WEKALA PLATFORM — Environment Variables Template
# Copy this file to .env and fill in REAL values before running the stack.
# NEVER commit .env to git.
#
# To generate JWT keys for Supabase:  make keygen
# =============================================================================

# =============================================================================
# SUPABASE
# =============================================================================

# Postgres superuser password (change before any production deploy)
POSTGRES_PASSWORD=dev_change_me_before_prod

# JWT signing secret — must be ≥ 32 characters
# Generate:  openssl rand -base64 40
SUPABASE_JWT_SECRET=dev_jwt_secret_change_me_at_least_32_chars_long

# JWT tokens derived from SUPABASE_JWT_SECRET.
# Generate both with:  make keygen
SUPABASE_ANON_KEY=CHANGE_ME_run_make_keygen
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_run_make_keygen

# Public URL Kong listens on (used by Studio + auth redirects)
SUPABASE_PUBLIC_URL=http://localhost:8000

# Studio
STUDIO_DEFAULT_ORGANIZATION="Wekala Dev"
STUDIO_DEFAULT_PROJECT=wekala-dev

# Auth
SITE_URL=http://localhost:3002
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

# SMTP (via MailHog for local dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@wekala.local
SMTP_SENDER_NAME="Wekala Dev"

# =============================================================================
# DIFY
# =============================================================================

# Generate:  make keygen
DIFY_SECRET_KEY=CHANGE_ME_run_make_keygen

DIFY_DB_PASSWORD=dify_dev_db_password
DIFY_REDIS_PASSWORD=dify_dev_redis_password

# Storage backend for Dify (local for POC; swap to s3/azure in prod)
DIFY_STORAGE_TYPE=local

# Sandbox (code execution) API key — matches dify-sandbox service
DIFY_SANDBOX_API_KEY=CHANGE_ME_run_make_keygen

# Dify console API token — used by the Wekala API to register/update agents in Dify.
# Obtain from: Dify Studio > Settings > API Keys > Console API
# NEVER expose this to the frontend.
DIFY_BASE_URL=http://dify-api:5001
DIFY_CONSOLE_TOKEN=CHANGE_ME_dify_console_api_token

# =============================================================================
# OLLAMA
# =============================================================================

OLLAMA_BASE_URL=http://ollama:11434

# Default models (pulled by `make pull-models`)
OLLAMA_DEFAULT_LLM=qwen2.5:7b-instruct
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_RERANKER_MODEL=bge-reranker-v2-m3

# =============================================================================
# MEILISEARCH
# =============================================================================

# Generate:  openssl rand -base64 32
MEILI_MASTER_KEY=CHANGE_ME_run_openssl_rand_base64_32
MEILI_ENV=development

# Wekala API: Meilisearch connection (mirrors MEILI_MASTER_KEY above)
MEILISEARCH_URL=http://wekala-meilisearch:7700
MEILISEARCH_MASTER_KEY=CHANGE_ME_run_openssl_rand_base64_32

# =============================================================================
# N8N
# =============================================================================

# Generate:  openssl rand -base64 32
N8N_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_base64_32
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_32
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=dev_change_me

# =============================================================================
# LANGFUSE
# =============================================================================

LANGFUSE_DB_PASSWORD=langfuse_dev_db_password

# Generate:  make keygen
LANGFUSE_SECRET_KEY=CHANGE_ME_run_make_keygen
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_run_make_keygen
LANGFUSE_SALT=CHANGE_ME_run_make_keygen

# Set to your Langfuse project keys after first login
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_HOST=http://langfuse:3000

# ClickHouse — internal event store for Langfuse v3 (not exposed outside Docker)
# Generate:  make keygen
CLICKHOUSE_PASSWORD=CHANGE_ME_run_make_keygen

# =============================================================================
# WEKALA — API (FastAPI, added Phase 1)
# =============================================================================

WEKALA_ENV=development
# Generate:  make keygen
WEKALA_SECRET_KEY=CHANGE_ME_run_make_keygen
WEKALA_CORS_ORIGINS=http://localhost:3002

# Points to Supabase Kong gateway
WEKALA_SUPABASE_URL=http://localhost:8000
WEKALA_SUPABASE_SERVICE_KEY=CHANGE_ME_same_as_SUPABASE_SERVICE_ROLE_KEY

# Postgres connection for Alembic migrations (run from host, not inside Docker)
# Uses localhost because the DB port is not exposed externally in this setup.
# For Docker-internal use, the compose service overrides this with the docker hostname.
DATABASE_URL=postgresql+asyncpg://postgres:dev_change_me_before_prod@localhost:5432/postgres

# OPA (Open Policy Agent) — internal Docker URL; override for local-only dev
OPA_URL=http://localhost:8181

# GoTrue password policy (enforced by supabase-auth)
GOTRUE_PASSWORD_MIN_LENGTH=12

# =============================================================================
# KNOWLEDGE BASE & RAG (Phase 4)
# =============================================================================

# ClamAV virus scanner sidecar (matches wekala-clamav Docker service)
CLAMAV_HOST=wekala-clamav
CLAMAV_PORT=3310

# Ollama embedding endpoint (same instance as LLM serving)
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_BATCH_SIZE=32

# Document ingestion limits
DOCUMENT_MAX_MB=50
DOCUMENT_CHUNK_TOKENS=1024
DOCUMENT_CHUNK_OVERLAP=128

# Supabase Storage internal URL (for the wekala-api service; not exposed externally)
SUPABASE_STORAGE_URL=http://supabase-storage:5000

# =============================================================================
# WEKALA — WEB (Next.js, added Phase 1)
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME_same_as_SUPABASE_ANON_KEY

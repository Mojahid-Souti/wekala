{
  "name": "wekala-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "pnpm --filter wekala-web exec biome ci .",
    "format": "pnpm --filter wekala-web exec biome format --write .",
    "type-check": "pnpm --filter wekala-web run type-check",
    "test": "pnpm --filter wekala-web test"
  },
  "pnpm": {
    "strictDepBuilds": false,
    "onlyBuiltDependencies": [],
    "ignoredBuiltDependencies": [
      "msw",
      "esbuild",
      "@biomejs/biome",
      "@tailwindcss/oxide",
      "core-js",
      "sharp",
      "unrs-resolver"
    ]
  }
}
